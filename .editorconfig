# Editor configuration for Project Cloak Access
# For more information, see https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,json,css,html,md,yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 120

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
